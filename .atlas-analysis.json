  "keyFeatures": [
    "Fernet symmetric encryption for all backups before upload",
    "Google Drive integration via OAuth2 and pydrive2",
    "Flexible scheduling: run once, daily, or weekly",
    "Dark mode tkinter GUI with progress bars and live log",
    "One-click restore: download, decrypt, and extract backups",
    "Automatic 5-backup rotation on Google Drive",
    "Local backup log in JSON format",
    "PyInstaller support for standalone EXE distribution"
